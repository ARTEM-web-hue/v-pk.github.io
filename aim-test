<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Тренировка аима - В ПК!</title>
    <Description>Тренировка аима, Аим тренировка, Тест аима - В ПК</Description>
    <link rel="icon" type="image/png" href="/assets/logo.png">
    <link rel="stylesheet" href="/assets/css/top-panel.css">
    
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            user-select: none;
        }

        body {
            font-family: 'Inter', 'Segoe UI', system-ui, sans-serif;
            background: radial-gradient(circle at 20% 20%, #1e1b4b, #0f0f1e);
            min-height: 100vh;
            position: relative;
            overflow-x: hidden;
        }

        .container {
            max-width: 1400px;
            margin: 40px auto;
            padding: 20px;
            display: flex;
            flex-direction: column;
            gap: 20px;
            position: relative;
            z-index: 1;
        }

        h1 {
            text-align: center;
            color: white;
            font-size: 3.5em;
            font-weight: 800;
            margin-bottom: 8px;
            letter-spacing: -1px;
            text-shadow: 0 0 30px rgba(59,130,246,0.5), 0 0 60px rgba(139,92,246,0.3);
        }

        .subtitle {
            text-align: center;
            color: #a5b4fc;
            margin-bottom: 20px;
            font-size: 1.2em;
            font-weight: 300;
            letter-spacing: 1px;
        }

        /* Переключатель режимов */
        .mode-switch {
            display: flex;
            justify-content: center;
            gap: 15px;
            margin-bottom: 30px;
            flex-wrap: wrap;
        }

        .mode-btn {
            background: rgba(20, 20, 40, 0.6);
            backdrop-filter: blur(12px);
            border: 2px solid rgba(59, 130, 246, 0.3);
            color: #a5b4fc;
            padding: 16px 32px;
            border-radius: 50px;
            font-size: 1.1em;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
            min-width: 200px;
            text-transform: uppercase;
            letter-spacing: 1px;
            box-shadow: 0 10px 20px -10px rgba(0,0,0,0.5);
        }

        .mode-btn:hover {
            border-color: #3b82f6;
            transform: translateY(-2px);
            color: white;
        }

        .mode-btn.active {
            background: linear-gradient(135deg, #3b82f6, #8b5cf6);
            border-color: transparent;
            color: white;
            box-shadow: 0 20px 40px -10px #3b82f6;
        }

        /* Панель статистики */
        .stats-panel {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            background: rgba(20, 20, 40, 0.6);
            backdrop-filter: blur(12px);
            border-radius: 40px;
            padding: 25px;
            border: 2px solid rgba(59, 130, 246, 0.2);
            box-shadow: 0 20px 40px -15px rgba(0,0,0,0.5);
        }

        .stat-item {
            text-align: center;
            padding: 10px;
            border-radius: 20px;
            background: rgba(0,0,0,0.2);
        }

        .stat-label {
            color: #94a3b8;
            font-size: 0.9em;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 8px;
        }

        .stat-value {
            color: white;
            font-size: 2.5em;
            font-weight: 800;
        }

        .stat-unit {
            color: #64748b;
            font-size: 0.5em;
            margin-left: 4px;
        }

        .stat-progress {
            height: 6px;
            background: rgba(255,255,255,0.1);
            border-radius: 3px;
            margin-top: 10px;
            overflow: hidden;
        }

        .stat-progress-fill {
            height: 100%;
            width: 0%;
            background: linear-gradient(90deg, #3b82f6, #8b5cf6);
            transition: width 0.3s;
        }

        /* Игровое поле */
        .game-area {
            background: rgba(0,0,0,0.4);
            backdrop-filter: blur(8px);
            border-radius: 60px;
            position: relative;
            height: 600px;
            overflow: hidden;
            border: 3px solid rgba(59, 130, 246, 0.3);
            box-shadow: 0 30px 60px -15px rgba(0,0,0,0.7);
            cursor: none;
        }

        #gameCanvas {
            width: 100%;
            height: 100%;
            display: block;
            cursor: none;
        }

        /* Прицел - БЕЗ УСКОРЕНИЯ */
        .crosshair {
            position: fixed;
            width: 40px;
            height: 40px;
            border: 3px solid rgba(255,255,255,0.9);
            border-radius: 50%;
            transform: translate(-50%, -50%);
            pointer-events: none;
            z-index: 1000;
            display: none;
            box-shadow: 0 0 30px rgba(59,130,246,0.5);
            will-change: left, top; /* Оптимизация для плавности */
            transition: none; /* Убираем все transition для точного следования */
        }

        .crosshair::before,
        .crosshair::after {
            content: '';
            position: absolute;
            background: rgba(255,255,255,0.9);
        }

        .crosshair::before {
            width: 20px;
            height: 3px;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
        }

        .crosshair::after {
            width: 3px;
            height: 20px;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
        }

        .crosshair.hit {
            border-color: #4ade80;
            box-shadow: 0 0 40px #4ade80;
        }

        .crosshair.hit::before,
        .crosshair.hit::after {
            background: #4ade80;
        }

        .crosshair.miss {
            border-color: #f87171;
            box-shadow: 0 0 30px #f87171;
        }

        .crosshair.miss::before,
        .crosshair.miss::after {
            background: #f87171;
        }

        /* Панель настроек */
        .settings-panel {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            background: rgba(20, 20, 40, 0.9);
            backdrop-filter: blur(20px);
            border-radius: 50px;
            padding: 40px;
            width: 550px;
            box-shadow: 0 40px 80px -20px rgba(0,0,0,0.8), 0 0 60px rgba(59,130,246,0.3);
            border: 2px solid rgba(59, 130, 246, 0.4);
            z-index: 2000;
        }

        .settings-panel.hidden {
            display: none;
        }

        .settings-title {
            color: white;
            font-size: 2.2em;
            font-weight: 700;
            text-align: center;
            margin-bottom: 30px;
        }

        .settings-group {
            margin-bottom: 30px;
            padding: 15px;
            background: rgba(0,0,0,0.2);
            border-radius: 30px;
            border: 1px solid rgba(59,130,246,0.2);
        }

        .settings-label {
            color: #a5b4fc;
            margin-bottom: 12px;
            display: flex;
            justify-content: space-between;
            font-size: 1.1em;
        }

        .settings-value {
            color: #3b82f6;
            font-weight: 600;
            background: rgba(0,0,0,0.3);
            padding: 4px 12px;
            border-radius: 50px;
        }

        input[type=range] {
            width: 100%;
            height: 8px;
            background: linear-gradient(90deg, #3b82f6, #8b5cf6);
            border-radius: 4px;
            -webkit-appearance: none;
        }

        input[type=range]::-webkit-slider-thumb {
            -webkit-appearance: none;
            width: 24px;
            height: 24px;
            background: white;
            border-radius: 50%;
            cursor: pointer;
            box-shadow: 0 0 30px #3b82f6;
            border: 3px solid #3b82f6;
        }

        .start-btn {
            background: linear-gradient(135deg, #3b82f6, #8b5cf6);
            color: white;
            border: none;
            width: 100%;
            padding: 20px;
            border-radius: 60px;
            font-size: 1.4em;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s;
            margin-top: 20px;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .start-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 30px 50px -10px #3b82f6;
        }

        /* Результаты */
        .results-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0,0,0,0.8);
            backdrop-filter: blur(20px);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 3000;
        }

        .results-overlay.hidden {
            display: none;
        }

        .results-card {
            background: rgba(20, 20, 40, 0.95);
            border-radius: 70px;
            padding: 60px;
            width: 600px;
            text-align: center;
            border: 2px solid rgba(59, 130, 246, 0.4);
            box-shadow: 0 40px 80px -20px black;
        }

        .results-title {
            color: white;
            font-size: 3em;
            font-weight: 800;
            margin-bottom: 40px;
        }

        .score-display {
            background: linear-gradient(135deg, #3b82f6, #8b5cf6);
            border-radius: 50px;
            padding: 40px;
            margin-bottom: 40px;
        }

        .score-label {
            color: rgba(255,255,255,0.9);
            font-size: 1.2em;
            margin-bottom: 15px;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .score-value {
            font-size: 5em;
            font-weight: 800;
            color: white;
        }

        .results-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 25px;
            margin-bottom: 40px;
        }

        .result-item {
            background: rgba(0,0,0,0.3);
            border-radius: 40px;
            padding: 25px;
            border: 1px solid rgba(59,130,246,0.3);
        }

        .result-item .label {
            color: #94a3b8;
            font-size: 1em;
            margin-bottom: 10px;
            text-transform: uppercase;
        }

        .result-item .value {
            color: white;
            font-size: 2.5em;
            font-weight: 700;
        }

        .new-record {
            color: #fbbf24;
            font-size: 2em;
            font-weight: 700;
            margin: 30px 0;
        }

        .play-again-btn {
            background: linear-gradient(135deg, #3b82f6, #8b5cf6);
            color: white;
            border: none;
            padding: 20px 50px;
            border-radius: 60px;
            font-size: 1.3em;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .play-again-btn:hover {
            transform: scale(1.05) translateY(-2px);
        }

        /* Таймер ожидания */
        .wait-timer {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            font-size: 6em;
            color: white;
            text-shadow: 0 0 50px #3b82f6;
            animation: pulse 1s infinite;
            z-index: 10;
            font-weight: 800;
        }

        @keyframes pulse {
            0%, 100% { transform: translate(-50%, -50%) scale(1); }
            50% { transform: translate(-50%, -50%) scale(1.1); }
        }

        /* История */
        .history-list {
            position: absolute;
            top: 20px;
            right: 20px;
            background: rgba(20, 20, 40, 0.6);
            backdrop-filter: blur(12px);
            border-radius: 40px;
            padding: 25px;
            width: 280px;
            border: 2px solid rgba(59, 130, 246, 0.3);
            z-index: 100;
        }

        .history-title {
            color: white;
            font-size: 1.3em;
            margin-bottom: 20px;
            text-align: center;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .history-items {
            max-height: 350px;
            overflow-y: auto;
        }

        .history-items::-webkit-scrollbar {
            width: 6px;
        }

        .history-items::-webkit-scrollbar-track {
            background: rgba(255,255,255,0.1);
            border-radius: 3px;
        }

        .history-items::-webkit-scrollbar-thumb {
            background: #3b82f6;
            border-radius: 3px;
        }

        .history-item {
            display: flex;
            justify-content: space-between;
            color: #94a3b8;
            padding: 12px 0;
            border-bottom: 1px solid rgba(59,130,246,0.2);
            font-size: 1em;
        }

        .history-item .score {
            color: #fbbf24;
            font-weight: 700;
        }

        .history-item .best {
            background: #fbbf24;
            color: #0f172a;
            padding: 4px 12px;
            border-radius: 30px;
            font-weight: 700;
        }

        @media (max-width: 1000px) {
            .stats-panel {
                grid-template-columns: repeat(2, 1fr);
            }
            
            .mode-switch {
                flex-direction: column;
                align-items: center;
            }
            
            .mode-btn {
                width: 100%;
                text-align: center;
            }
            
            .history-list {
                display: none;
            }
            
            .settings-panel {
                width: 90%;
                padding: 30px;
            }
            
            .results-card {
                width: 90%;
                padding: 30px;
            }
        }
    </style>
</head>
<body>
    <div id="top-panel-placeholder"></div>

    <!-- Кастомный прицел - теперь без ускорения -->
    <div class="crosshair" id="crosshair"></div>

    <!-- Переключатель режимов -->
    <div class="container">
        <h1>🎯 Aim Master</h1>
        <div class="subtitle">Мгновенное переключение между режимами</div>

        <div class="mode-switch">
            <button class="mode-btn active" onclick="switchModeInstant('classic')">🎯 Классический</button>
            <button class="mode-btn" onclick="switchModeInstant('speedReaction')">⚡ Скоростная реакция</button>
            <button class="mode-btn" onclick="switchModeInstant('chaos')">🌀 Хаос</button>
        </div>

        <!-- Панель статистики -->
        <div class="stats-panel">
            <div class="stat-item">
                <div class="stat-label">Счёт</div>
                <div class="stat-value" id="score">0</div>
            </div>
            <div class="stat-item">
                <div class="stat-label">Попадания</div>
                <div class="stat-value" id="hits">0</div>
            </div>
            <div class="stat-item">
                <div class="stat-label">Промахи</div>
                <div class="stat-value" id="misses">0</div>
            </div>
            <div class="stat-item">
                <div class="stat-label">Точность</div>
                <div class="stat-value" id="accuracy">0<span class="stat-unit">%</span></div>
                <div class="stat-progress">
                    <div class="stat-progress-fill" id="accuracyBar"></div>
                </div>
            </div>
        </div>

        <!-- Игровое поле -->
        <div class="game-area" id="gameArea">
            <canvas id="gameCanvas"></canvas>
            <div id="waitTimer" class="wait-timer" style="display: none;"></div>
        </div>
    </div>

    <!-- Панель настроек -->
    <div class="settings-panel" id="settingsPanel">
        <div class="settings-title" id="settingsTitle">⚙️ Настройки</div>
        
        <!-- Настройки для классического режима -->
        <div id="classicSettings">
            <div class="settings-group">
                <div class="settings-label">
                    <span>🎯 Режим</span>
                    <span class="settings-value" id="classicModeDisplay">Таймер</span>
                </div>
                <div style="display: flex; gap: 10px;">
                    <button class="mode-btn" style="padding: 10px;" onclick="setClassicMode('timer')">⏱️ Таймер</button>
                    <button class="mode-btn" style="padding: 10px;" onclick="setClassicMode('targets')">🎯 Цели</button>
                </div>
            </div>

            <div class="settings-group" id="classicTimerSettings">
                <div class="settings-label">
                    <span>⏱️ Время (сек)</span>
                    <span class="settings-value" id="classicTimeValue">30</span>
                </div>
                <input type="range" id="classicTimeSlider" min="10" max="120" value="30" step="5" oninput="updateClassicTime()">
            </div>

            <div class="settings-group" id="classicTargetsSettings" style="display: none;">
                <div class="settings-label">
                    <span>🎯 Количество целей</span>
                    <span class="settings-value" id="classicTargetsValue">30</span>
                </div>
                <input type="range" id="classicTargetsSlider" min="10" max="100" value="30" step="5" oninput="updateClassicTargets()">
            </div>
        </div>

        <!-- Настройки для скоростной реакции -->
        <div id="speedReactionSettings" style="display: none;">
            <div class="settings-group">
                <div class="settings-label">
                    <span>🎯 Количество целей</span>
                    <span class="settings-value" id="speedTargetsCount">5</span>
                </div>
                <input type="range" id="speedTargetsSlider" min="1" max="20" value="5" step="1" oninput="updateSpeedTargets()">
            </div>
        </div>

        <!-- Настройки для хаоса -->
        <div id="chaosSettings" style="display: none;">
            <div class="settings-group">
                <div class="settings-label">
                    <span>🌀 Количество целей</span>
                    <span class="settings-value" id="chaosTargetsCount">10</span>
                </div>
                <input type="range" id="chaosTargetsSlider" min="5" max="30" value="10" step="1" oninput="updateChaosTargets()">
            </div>
            <div class="settings-group">
                <div class="settings-label">
                    <span>⚡ Скорость</span>
                    <span class="settings-value" id="chaosSpeedDisplay">Средняя</span>
                </div>
                <input type="range" id="chaosSpeedSlider" min="1" max="5" value="2" step="0.5" oninput="updateChaosSpeed()">
            </div>
        </div>

        <!-- Общие настройки -->
        <div class="settings-group">
            <div class="settings-label">
                <span>📏 Размер цели</span>
                <span class="settings-value" id="globalSizeValue">Средний</span>
            </div>
            <div style="display: flex; gap: 10px; justify-content: center;">
                <button class="mode-btn" style="padding: 8px;" onclick="setGlobalSize('small')">Маленький</button>
                <button class="mode-btn" style="padding: 8px;" onclick="setGlobalSize('medium')">Средний</button>
                <button class="mode-btn" style="padding: 8px;" onclick="setGlobalSize('large')">Большой</button>
            </div>
        </div>

        <button class="start-btn" onclick="startGame()">🚀 Начать игру</button>
    </div>

    <!-- Результаты -->
    <div class="results-overlay hidden" id="resultsOverlay">
        <div class="results-card">
            <div class="results-title" id="resultsTitle">🎯 Результаты</div>
            
            <div class="score-display">
                <div class="score-label" id="resultScoreLabel">Итоговый счёт</div>
                <div class="score-value" id="finalScore">0</div>
            </div>

            <div class="results-grid">
                <div class="result-item">
                    <div class="label">Попадания</div>
                    <div class="value" id="resultHits">0</div>
                </div>
                <div class="result-item">
                    <div class="label">Промахи</div>
                    <div class="value" id="resultMisses">0</div>
                </div>
                <div class="result-item">
                    <div class="label">Точность</div>
                    <div class="value" id="resultAccuracy">0%</div>
                </div>
                <div class="result-item">
                    <div class="label">Время</div>
                    <div class="value" id="resultTime">0.0с</div>
                </div>
            </div>

            <div id="recordMessage" class="new-record" style="display: none;">🏆 Новый рекорд!</div>

            <button class="play-again-btn" onclick="showSettings()">🔄 Играть снова</button>
        </div>
    </div>

    <!-- История -->
    <div class="history-list">
        <div class="history-title">📜 Рейтинг</div>
        <div class="history-items" id="historyItems">
            <div class="history-item">Нет данных</div>
        </div>
    </div>

    <script src="/assets/js/top-panel.js"></script>
    
    <script>
        // ==================== СОСТОЯНИЕ ====================
        let currentMode = 'classic';
        let gameState = {
            active: false,
            waiting: false,
            startTime: null,
            reactionStartTime: null,
            hits: 0,
            misses: 0,
            score: 0,
            targets: [],
            animationId: null,
            lastClickTime: 0,
            clickCooldown: 50,
            bestScore: localStorage.getItem('aimBestScore') || 0,
            history: JSON.parse(localStorage.getItem('aimHistory')) || [],
            timeLimit: null,
            targetsRemaining: null,
            modeStartTime: null
        };

        // Настройки для разных режимов
        let classicMode = 'timer';
        let classicTime = 30;
        let classicTargets = 30;
        let speedTargets = 5;
        let chaosTargets = 10;
        let chaosSpeed = 2;
        let globalSize = 'medium';

        // Размеры целей
        const targetSizes = {
            small: 20,
            medium: 35,
            large: 50
        };

        // Canvas
        const canvas = document.getElementById('gameCanvas');
        const ctx = canvas.getContext('2d');
        const gameArea = document.getElementById('gameArea');

        // Прицел - получаем элемент
        const crosshair = document.getElementById('crosshair');

        // ==================== МГНОВЕННОЕ ПЕРЕКЛЮЧЕНИЕ РЕЖИМОВ ====================
        function switchModeInstant(mode) {
            currentMode = mode;
            
            document.querySelectorAll('.mode-btn').forEach(btn => {
                btn.classList.remove('active');
            });
            event.currentTarget.classList.add('active');
            
            resetGameForMode();
            startGame();
        }

        function resetGameForMode() {
            if (gameState.animationId) {
                cancelAnimationFrame(gameState.animationId);
                gameState.animationId = null;
            }
            
            gameState.waiting = false;
            gameState.targets = [];
            gameState.timeLimit = null;
            gameState.targetsRemaining = null;
            gameState.modeStartTime = Date.now();
            
            document.getElementById('waitTimer').style.display = 'none';
        }

        // ==================== НАСТРОЙКИ ====================
        function setClassicMode(mode) {
            classicMode = mode;
            document.getElementById('classicModeDisplay').textContent = mode === 'timer' ? 'Таймер' : 'Цели';
            if (mode === 'timer') {
                document.getElementById('classicTimerSettings').style.display = 'block';
                document.getElementById('classicTargetsSettings').style.display = 'none';
            } else {
                document.getElementById('classicTimerSettings').style.display = 'none';
                document.getElementById('classicTargetsSettings').style.display = 'block';
            }
        }

        function updateClassicTime() {
            classicTime = parseInt(document.getElementById('classicTimeSlider').value);
            document.getElementById('classicTimeValue').textContent = classicTime;
        }

        function updateClassicTargets() {
            classicTargets = parseInt(document.getElementById('classicTargetsSlider').value);
            document.getElementById('classicTargetsValue').textContent = classicTargets;
        }

        function updateSpeedTargets() {
            speedTargets = parseInt(document.getElementById('speedTargetsSlider').value);
            document.getElementById('speedTargetsCount').textContent = speedTargets;
        }

        function updateChaosTargets() {
            chaosTargets = parseInt(document.getElementById('chaosTargetsSlider').value);
            document.getElementById('chaosTargetsCount').textContent = chaosTargets;
        }

        function updateChaosSpeed() {
            chaosSpeed = parseFloat(document.getElementById('chaosSpeedSlider').value);
            const speedNames = {1: 'Медленная', 2: 'Средняя', 3: 'Быстрая', 4: 'Очень быстрая', 5: 'Сверхзвуковая'};
            document.getElementById('chaosSpeedDisplay').textContent = speedNames[chaosSpeed] || 'Средняя';
        }

        function setGlobalSize(size) {
            globalSize = size;
            const names = { small: 'Маленький', medium: 'Средний', large: 'Большой' };
            document.getElementById('globalSizeValue').textContent = names[size];
        }

        // ==================== УПРАВЛЕНИЕ ИГРОЙ ====================
        function showSettings() {
            if (gameState.active) {
                stopGame();
            }
            document.getElementById('settingsPanel').classList.remove('hidden');
            document.getElementById('resultsOverlay').classList.add('hidden');
        }

        function stopGame() {
            gameState.active = false;
            gameState.waiting = false;
            if (gameState.animationId) {
                cancelAnimationFrame(gameState.animationId);
                gameState.animationId = null;
            }
            document.getElementById('waitTimer').style.display = 'none';
            crosshair.style.display = 'none';
        }

        function startGame() {
            document.getElementById('settingsPanel').classList.add('hidden');
            
            if (!gameState.modeStartTime) {
                gameState.hits = 0;
                gameState.misses = 0;
                gameState.score = 0;
            }
            
            gameState.targets = [];
            gameState.active = true;
            gameState.timeLimit = null;
            gameState.targetsRemaining = null;
            gameState.modeStartTime = Date.now();
            
            updateStats();
            
            crosshair.style.display = 'block';
            gameArea.style.cursor = 'none';
            
            if (currentMode === 'classic') {
                startClassicMode();
            } else if (currentMode === 'speedReaction') {
                startSpeedReaction();
            } else if (currentMode === 'chaos') {
                startChaosMode();
            }
        }

        // ==================== КЛАССИЧЕСКИЙ РЕЖИМ ====================
        function startClassicMode() {
            gameState.reactionStartTime = Date.now();
            gameState.waiting = false;
            
            if (classicMode === 'timer') {
                gameState.timeLimit = classicTime;
            } else {
                gameState.targetsRemaining = classicTargets;
            }
            
            createTarget('normal');
            
            if (!gameState.animationId) {
                gameLoop();
            }
        }

        // ==================== СКОРОСТНАЯ РЕАКЦИЯ ====================
        function startSpeedReaction() {
            gameState.waiting = true;
            const delay = 1600 + Math.random() * 3000;
            const waitTimer = document.getElementById('waitTimer');
            
            waitTimer.style.display = 'block';
            waitTimer.textContent = '⚡';
            
            if (gameState.speedTimer) {
                clearTimeout(gameState.speedTimer);
            }
            
            gameState.speedTimer = setTimeout(() => {
                if (!gameState.active) return;
                
                waitTimer.style.display = 'none';
                gameState.waiting = false;
                gameState.reactionStartTime = Date.now();
                
                for (let i = 0; i < speedTargets; i++) {
                    createTarget('normal');
                }
                
                if (!gameState.animationId) {
                    gameLoop();
                }
            }, delay);
        }

        // ==================== РЕЖИМ ХАОСА ====================
        function startChaosMode() {
            gameState.waiting = false;
            gameState.reactionStartTime = Date.now();
            
            for (let i = 0; i < chaosTargets; i++) {
                createTarget('chaos');
            }
            
            if (!gameState.animationId) {
                gameLoop();
            }
        }

        // ==================== СОЗДАНИЕ ЦЕЛЕЙ ====================
        function createTarget(type) {
            const baseSize = targetSizes[globalSize];
            
            if (type === 'chaos') {
                const shapes = ['circle', 'square', 'triangle', 'star', 'diamond', 'hexagon'];
                const colors = [
                    '#ef4444', '#3b82f6', '#4ade80', '#fbbf24', '#8b5cf6',
                    '#ec4899', '#14b8a6', '#f97316', '#ff6b6b', '#4ecdc4'
                ];
                
                const size = baseSize * (0.7 + Math.random() * 1.3);
                const speed = chaosSpeed * (0.5 + Math.random() * 0.5);
                const angle = Math.random() * Math.PI * 2;
                
                gameState.targets.push({
                    id: Date.now() + Math.random(),
                    x: Math.random() * (canvas.width - size * 2) + size,
                    y: Math.random() * (canvas.height - size * 2) + size,
                    vx: Math.cos(angle) * speed,
                    vy: Math.sin(angle) * speed,
                    size: size,
                    shape: shapes[Math.floor(Math.random() * shapes.length)],
                    color: colors[Math.floor(Math.random() * colors.length)],
                    rotation: Math.random() * Math.PI * 2,
                    rotationSpeed: (Math.random() - 0.5) * 0.1,
                    type: 'chaos'
                });
            } else {
                const speed = 1 + Math.random() * 2;
                const angle = Math.random() * Math.PI * 2;
                
                gameState.targets.push({
                    id: Date.now() + Math.random(),
                    x: Math.random() * (canvas.width - baseSize * 2) + baseSize,
                    y: Math.random() * (canvas.height - baseSize * 2) + baseSize,
                    vx: Math.cos(angle) * speed,
                    vy: Math.sin(angle) * speed,
                    size: baseSize,
                    type: 'normal'
                });
            }
        }

        // ==================== ОБНОВЛЕНИЕ ПОЗИЦИЙ ====================
        function updateTargets() {
            for (let i = gameState.targets.length - 1; i >= 0; i--) {
                const target = gameState.targets[i];
                
                target.x += target.vx;
                target.y += target.vy;
                
                if (target.x < target.size) {
                    target.x = target.size;
                    target.vx *= -0.9;
                }
                if (target.x > canvas.width - target.size) {
                    target.x = canvas.width - target.size;
                    target.vx *= -0.9;
                }
                if (target.y < target.size) {
                    target.y = target.size;
                    target.vy *= -0.9;
                }
                if (target.y > canvas.height - target.size) {
                    target.y = canvas.height - target.size;
                    target.vy *= -0.9;
                }
                
                target.rotation += target.rotationSpeed || 0;
            }
        }

        // ==================== ОТРИСОВКА ====================
        function drawTargets() {
            gameState.targets.forEach(target => {
                ctx.save();
                ctx.translate(target.x, target.y);
                ctx.rotate(target.rotation || 0);
                
                if (target.type === 'chaos') {
                    ctx.fillStyle = target.color;
                    
                    switch(target.shape) {
                        case 'circle':
                            ctx.beginPath();
                            ctx.arc(0, 0, target.size / 2, 0, Math.PI * 2);
                            ctx.fill();
                            break;
                        case 'square':
                            ctx.fillRect(-target.size/2, -target.size/2, target.size, target.size);
                            break;
                        case 'triangle':
                            ctx.beginPath();
                            ctx.moveTo(0, -target.size/2);
                            ctx.lineTo(target.size/2, target.size/2);
                            ctx.lineTo(-target.size/2, target.size/2);
                            ctx.closePath();
                            ctx.fill();
                            break;
                        case 'star':
                            drawStar(ctx, 0, 0, 5, target.size/2, target.size/4);
                            ctx.fill();
                            break;
                        case 'diamond':
                            ctx.beginPath();
                            ctx.moveTo(0, -target.size/2);
                            ctx.lineTo(target.size/2, 0);
                            ctx.lineTo(0, target.size/2);
                            ctx.lineTo(-target.size/2, 0);
                            ctx.closePath();
                            ctx.fill();
                            break;
                        case 'hexagon':
                            drawPolygon(ctx, 0, 0, 6, target.size/2);
                            ctx.fill();
                            break;
                    }
                    
                    ctx.fillStyle = '#000000';
                    ctx.beginPath();
                    ctx.arc(-target.size/4, -target.size/4, target.size/10, 0, Math.PI * 2);
                    ctx.fill();
                    ctx.beginPath();
                    ctx.arc(target.size/4, -target.size/4, target.size/10, 0, Math.PI * 2);
                    ctx.fill();
                } else {
                    ctx.beginPath();
                    ctx.arc(0, 0, target.size / 2, 0, Math.PI * 2);
                    ctx.fillStyle = '#ef4444';
                    ctx.fill();
                    ctx.strokeStyle = 'white';
                    ctx.lineWidth = 2;
                    ctx.stroke();
                    
                    ctx.beginPath();
                    ctx.arc(0, 0, target.size / 4, 0, Math.PI * 2);
                    ctx.fillStyle = 'white';
                    ctx.fill();
                }
                
                ctx.restore();
            });
        }

        // Вспомогательные функции для рисования
        function drawStar(ctx, cx, cy, spikes, outerR, innerR) {
            let rot = Math.PI / 2 * 3;
            const step = Math.PI / spikes;
            ctx.beginPath();
            for (let i = 0; i < spikes; i++) {
                const x = cx + Math.cos(rot) * outerR;
                const y = cy + Math.sin(rot) * outerR;
                ctx.lineTo(x, y);
                rot += step;
                
                const x2 = cx + Math.cos(rot) * innerR;
                const y2 = cy + Math.sin(rot) * innerR;
                ctx.lineTo(x2, y2);
                rot += step;
            }
            ctx.closePath();
        }

        function drawPolygon(ctx, cx, cy, sides, radius) {
            ctx.beginPath();
            for (let i = 0; i < sides; i++) {
                const angle = (i / sides) * Math.PI * 2;
                const x = cx + Math.cos(angle) * radius;
                const y = cy + Math.sin(angle) * radius;
                if (i === 0) ctx.moveTo(x, y);
                else ctx.lineTo(x, y);
            }
            ctx.closePath();
        }

        // ==================== ПОПАДАНИЕ ====================
        function checkHit(x, y) {
            const now = Date.now();
            if (now - gameState.lastClickTime < gameState.clickCooldown) return false;
            gameState.lastClickTime = now;
            
            if (!gameState.active || gameState.waiting) return false;
            
            for (let i = gameState.targets.length - 1; i >= 0; i--) {
                const target = gameState.targets[i];
                const distance = Math.hypot(x - target.x, y - target.y);
                
                if (distance < target.size / 2) {
                    gameState.targets.splice(i, 1);
                    gameState.hits++;
                    gameState.score += 10;
                    
                    if (currentMode === 'classic' && classicMode === 'targets') {
                        gameState.targetsRemaining--;
                        if (gameState.targetsRemaining > 0) {
                            createTarget('normal');
                        }
                    } else if (currentMode === 'classic' && classicMode === 'timer') {
                        createTarget('normal');
                    }
                    
                    crosshair.classList.add('hit');
                    setTimeout(() => crosshair.classList.remove('hit'), 100);
                    
                    if ((currentMode === 'speedReaction' || currentMode === 'chaos') && 
                        gameState.targets.length === 0) {
                        endGame();
                    }
                    if (currentMode === 'classic' && classicMode === 'targets' && 
                        gameState.targetsRemaining <= 0 && gameState.targets.length === 0) {
                        endGame();
                    }
                    
                    updateStats();
                    return true;
                }
            }
            
            crosshair.classList.add('miss');
            setTimeout(() => crosshair.classList.remove('miss'), 100);
            gameState.misses++;
            gameState.score = Math.max(0, gameState.score - 5);
            updateStats();
            
            return false;
        }

        // ==================== СТАТИСТИКА ====================
        function updateStats() {
            document.getElementById('score').textContent = gameState.score;
            document.getElementById('hits').textContent = gameState.hits;
            document.getElementById('misses').textContent = gameState.misses;
            
            const total = gameState.hits + gameState.misses;
            const accuracy = total > 0 ? Math.round(gameState.hits / total * 100) : 0;
            document.getElementById('accuracy').textContent = accuracy + '%';
            document.getElementById('accuracyBar').style.width = accuracy + '%';
        }

        // ==================== ИГРОВОЙ ЦИКЛ ====================
        function gameLoop() {
            if (!gameState.active) return;
            
            canvas.width = gameArea.clientWidth;
            canvas.height = gameArea.clientHeight;
            
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            
            updateTargets();
            drawTargets();
            
            if (currentMode === 'classic' && classicMode === 'timer' && gameState.reactionStartTime) {
                const elapsed = (Date.now() - gameState.reactionStartTime) / 1000;
                if (elapsed >= classicTime) {
                    endGame();
                }
            }
            
            gameState.animationId = requestAnimationFrame(gameLoop);
        }

        // ==================== ЗАВЕРШЕНИЕ ====================
        function endGame() {
            gameState.active = false;
            crosshair.style.display = 'none';
            
            const totalTime = gameState.reactionStartTime ? 
                ((Date.now() - gameState.reactionStartTime) / 1000).toFixed(1) : '0.0';
            
            const total = gameState.hits + gameState.misses;
            const accuracy = total > 0 ? Math.round(gameState.hits / total * 100) : 0;
            
            const modeNames = {
                classic: '🎯 Классический',
                speedReaction: '⚡ Скоростная реакция',
                chaos: '🌀 Хаос'
            };
            
            document.getElementById('resultsTitle').textContent = modeNames[currentMode];
            document.getElementById('finalScore').textContent = gameState.score;
            document.getElementById('resultHits').textContent = gameState.hits;
            document.getElementById('resultMisses').textContent = gameState.misses;
            document.getElementById('resultAccuracy').textContent = accuracy + '%';
            document.getElementById('resultTime').textContent = totalTime + 'с';
            
            const result = {
                score: gameState.score,
                accuracy: accuracy,
                mode: currentMode,
                date: new Date().toLocaleString()
            };
            
            gameState.history.unshift(result);
            if (gameState.history.length > 20) gameState.history.pop();
            localStorage.setItem('aimHistory', JSON.stringify(gameState.history));
            
            if (gameState.score > gameState.bestScore) {
                gameState.bestScore = gameState.score;
                localStorage.setItem('aimBestScore', gameState.score);
                document.getElementById('recordMessage').style.display = 'block';
            } else {
                document.getElementById('recordMessage').style.display = 'none';
            }
            
            document.getElementById('resultsOverlay').classList.remove('hidden');
            updateHistory();
        }

        // ==================== ИСТОРИЯ ====================
        function updateHistory() {
            const historyItems = document.getElementById('historyItems');
            if (gameState.history.length === 0) {
                historyItems.innerHTML = '<div class="history-item">Нет данных</div>';
                return;
            }

            const sortedHistory = [...gameState.history].sort((a, b) => b.score - a.score).slice(0, 10);
            
            historyItems.innerHTML = sortedHistory.map((item, index) => `
                <div class="history-item">
                    <span>${index + 1}. ${item.score} очков</span>
                    <span class="${item.score === gameState.bestScore ? 'best' : 'score'}">${item.accuracy}%</span>
                </div>
            `).join('');
        }

        // ==================== ОБРАБОТЧИКИ МЫШИ - ТОЧНОЕ СЛЕДОВАНИЕ ====================
        gameArea.addEventListener('mousemove', (e) => {
            if (!gameState.active) return;
            
            // Прямое присвоение координат - БЕЗ УСКОРЕНИЯ
            crosshair.style.left = e.clientX + 'px';
            crosshair.style.top = e.clientY + 'px';
        });

        gameArea.addEventListener('click', (e) => {
            e.preventDefault();
            
            if (!gameState.active || gameState.waiting) return;
            
            const rect = canvas.getBoundingClientRect();
            const x = e.clientX - rect.left;
            const y = e.clientY - rect.top;
            
            checkHit(x, y);
        });

        gameArea.addEventListener('mouseleave', () => {
            crosshair.style.display = 'none';
        });

        gameArea.addEventListener('mouseenter', () => {
            if (gameState.active) {
                crosshair.style.display = 'block';
            }
        });

        // ==================== ИНИЦИАЛИЗАЦИЯ ====================
        document.querySelector('.mode-btn').classList.add('active');
        document.getElementById('bestScore').textContent = gameState.bestScore;
        updateHistory();
        
        setClassicMode('timer');
        updateChaosSpeed();
    </script>
</body>
</html>
